{
  "name": "linktrail",
  "version": "0.16.0",
  "private": true,
  "type": "module",
  "description": "Capture the current tab into a personal RSS-backed reading history.",
  "scripts": {
    "test": "bun test",
    "migrate": "bun run scripts/migrate.ts",
    "reset": "bun run scripts/reset-items.ts",
    "export": "bun run scripts/export.ts",
    "import": "bun run scripts/import.ts",
    "build:ext": "vite build --config extension/vite.config.ts",
    "dev:ext": "vite --config extension/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "package": "bun run scripts/package.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@neondatabase/serverless": "^0.10.4",
    "dompurify": "^3.4.11",
    "linkedom": "^0.18.12",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.6",
    "bun-types": "^1.3.14",
    "typescript": "^5.7.0",
    "vite": "^5.4.0"
  }
}
